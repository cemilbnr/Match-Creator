# Normalize line endings across Windows / macOS / Linux contributors.
* text=auto eol=lf

# Windows batch + PowerShell keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary blobs — never touch line endings.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.blend binary
*.msi binary
*.exe binary
*.zip binary
